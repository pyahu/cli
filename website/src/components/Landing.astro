---
import BaseLayout from "../layouts/BaseLayout.astro";
import { ui, type Lang } from "../i18n/landing";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = ui[lang];

const base = lang === "en" ? "/en" : "";
const docs = `${base}/docs`;
const installFoot = t.install.foot.replace("$DOCS", docs);
---

<BaseLayout lang={lang} title={t.meta.title} description={t.meta.description} current="home">
  <section class="hero">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="hero-grid">
      <div class="hero-content">
        <p class="eyebrow">{t.hero.eyebrow}</p>
        <h1>{t.hero.titleLead} <span>{t.hero.titleAccent}</span></h1>
        <p class="hero-copy">{t.hero.copy}</p>
        <div class="hero-actions">
          <a class="button primary" href={`${docs}/instalacao`}>{t.hero.ctaStart}</a>
          <a class="button secondary" href={`${docs}/comandos`}>{t.hero.ctaCommands}</a>
        </div>
        <div class="hero-install">
          <span class="hero-install-prompt">$</span>
          <code>curl -fsSL https://cli.pyahu.io/install.sh | sh</code>
        </div>
        <p class="hero-meta">{t.hero.meta}</p>
      </div>

      <div class="terminal" role="img" aria-label={t.hero.terminalAlt}>
        <div class="terminal-bar">
          <span class="dot dot-red"></span>
          <span class="dot dot-amber"></span>
          <span class="dot dot-green"></span>
          <span class="terminal-title">pyahu-local</span>
        </div>
        <pre class="terminal-body"><code><span class="t-prompt">$</span> <span class="t-cmd">pyahu up</span>
<span class="t-tag">[preflight]</span> <span class="t-dim">{t.hero.term.preflight}</span> <span class="t-ok">OK</span>
<span class="t-tag">[cluster]</span>   <span class="t-dim">{t.hero.term.cluster}</span>
<span class="t-tag">[certs]</span>     <span class="t-dim">Secret</span> pyahu-local-tls <span class="t-dim">{t.hero.term.certsApplied}</span>
<span class="t-tag">[services]</span>  <span class="t-dim">{t.hero.term.services}</span>

<span class="t-ok">Pyahu local stack is ready</span>

<span class="t-prompt">$</span> <span class="t-cmd">pyahu services</span>
<span class="t-head">SERVICE        STATUS  ENDPOINTS</span>
postgres       <span class="t-ok">ready</span>   localhost:5432
zitadel        <span class="t-ok">ready</span>   https://zitadel.localhost
rabbitmq       <span class="t-ok">ready</span>   localhost:5672
kafka-connect  <span class="t-ok">ready</span>   http://localhost:8083

<span class="t-prompt">$</span> <span class="t-cmd">curl</span> https://zitadel.localhost/debug/healthz
<span class="t-ok">ok</span><span class="t-caret">▋</span></code></pre>
      </div>
    </div>
  </section>

  <section class="section services-section" aria-labelledby="services-title">
    <div class="section-heading">
      <p class="eyebrow">{t.services.eyebrow}</p>
      <h2 id="services-title">{t.services.title}</h2>
      <p class="section-lead">{t.services.lead}</p>
    </div>
    <div class="service-grid">
      {
        t.services.items.map((service) => (
          <article class={`service-card accent-${service.accent}`}>
            <div class="service-top">
              <span class="service-dot" aria-hidden="true"></span>
              <h3>{service.name}</h3>
            </div>
            <p>{service.role}</p>
            <code class="service-endpoint">{service.endpoint}</code>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section split-section platform-section" aria-labelledby="platform-title">
    <div class="split-copy">
      <p class="eyebrow">{t.platform.eyebrow}</p>
      <h2 id="platform-title">{t.platform.title}</h2>
      <p set:html={t.platform.copy} />
      <a class="text-link" href={docs}>{t.platform.link}</a>
    </div>
    <pre class="code-panel"><code><span class="t-prompt">$</span> export KUBECONFIG="$(pyahu kubeconfig)"
<span class="t-prompt">$</span> <span class="t-cmd">kubectl</span> get ingress,pvc,cm,secret -n pyahu-local-dev
ingress/zitadel         <span class="t-dim">zitadel.localhost</span>
ingress/kafka-ui        <span class="t-dim">kafka-ui.localhost</span>
pvc/postgres-data       <span class="t-ok">Bound</span>
configmap/rabbitmq-config
secret/pyahu-local-tls  <span class="t-dim">kubernetes.io/tls</span></code></pre>
  </section>

  <section class="section steps-section" id="quickstart" aria-labelledby="steps-title">
    <div class="section-heading">
      <p class="eyebrow">{t.steps.eyebrow}</p>
      <h2 id="steps-title">{t.steps.title}</h2>
    </div>
    <div class="steps-grid">
      {
        t.steps.items.map((step) => (
          <article class="step-card">
            <span class="step-number">{step.n}</span>
            <h3>{step.title}</h3>
            <p>{step.text}</p>
            <div class="step-code">
              <span>$</span>
              <code>{step.code}</code>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section install-section" id="instalar" aria-labelledby="install-title">
    <div class="section-heading">
      <p class="eyebrow">{t.install.eyebrow}</p>
      <h2 id="install-title">{t.install.title}</h2>
      <p class="section-lead">{t.install.lead}</p>
    </div>

    <div class="install-widget" data-install>
      <div class="install-tabs" role="tablist" aria-label="Pyahu CLI">
        <button class="install-tab is-active" role="tab" aria-selected="true" data-tab="script">Script</button>
        <button class="install-tab" role="tab" aria-selected="false" data-tab="go">Go</button>
        <button class="install-tab" role="tab" aria-selected="false" data-tab="release">Releases</button>
      </div>
      <div class="install-panels">
        <pre class="install-panel is-active" role="tabpanel" data-panel="script"><code><span class="t-comment">{t.install.comments.script}</span>
<span class="t-prompt">$</span> curl -fsSL https://cli.pyahu.io/install.sh | sh
<span class="t-prompt">$</span> pyahu --version</code></pre>
        <pre class="install-panel" role="tabpanel" data-panel="go" hidden><code><span class="t-comment">{t.install.comments.go}</span>
<span class="t-prompt">$</span> go install github.com/pyahu/cli/cmd/pyahu@latest</code></pre>
        <pre class="install-panel" role="tabpanel" data-panel="release" hidden><code><span class="t-comment">{t.install.comments.release}</span>
<span class="t-prompt">$</span> tar -xzf pyahu_Linux_x86_64.tar.gz
<span class="t-prompt">$</span> sudo mv pyahu /usr/local/bin/</code></pre>
      </div>
    </div>
    <p class="install-foot" set:html={installFoot} />
  </section>

  <section class="section split-section tls-section" aria-labelledby="tls-title">
    <div class="split-copy">
      <p class="eyebrow">{t.tls.eyebrow}</p>
      <h2 id="tls-title">{t.tls.title}</h2>
      <p set:html={t.tls.copy} />
      <a class="text-link" href={`${docs}/certificados`}>{t.tls.link}</a>
    </div>
    <pre class="code-panel"><code><span class="t-prompt">$</span> pyahu certs status
<span class="t-dim">CA status:  </span> <span class="t-ok">valid until 2036-06-19</span>
<span class="t-dim">host trust: </span> not trusted

<span class="t-prompt">$</span> pyahu certs trust
<span class="t-dim">trusted local CA</span>

<span class="t-prompt">$</span> curl https://zitadel.localhost/debug/healthz
<span class="t-ok">ok</span></code></pre>
  </section>

  <section class="section split-section split-reverse cdc-section" aria-labelledby="cdc-title">
    <div class="split-copy">
      <p class="eyebrow">{t.cdc.eyebrow}</p>
      <h2 id="cdc-title">{t.cdc.title}</h2>
      <p set:html={t.cdc.copy} />
      <a class="text-link" href={`${docs}/kafka-connect-debezium`}>{t.cdc.link}</a>
    </div>
    <pre class="code-panel"><code><span class="t-comment">services:</span>
  <span class="t-key">kafkaConnect:</span>
    <span class="t-key">enabled:</span> true
    <span class="t-key">connectors:</span>
      - <span class="t-key">name:</span> app-cdc
        <span class="t-key">type:</span> source
        <span class="t-key">kind:</span> debezium.postgres
        <span class="t-key">tables:</span>
          <span class="t-key">include:</span>
            - public.orders</code></pre>
  </section>

  <section class="section capabilities-section" aria-labelledby="cap-title">
    <div class="section-heading">
      <p class="eyebrow">{t.capabilities.eyebrow}</p>
      <h2 id="cap-title">{t.capabilities.title}</h2>
    </div>
    <div class="capability-grid">
      {
        t.capabilities.items.map((item) => (
          <article class="capability-card">
            <h3>{item.label}</h3>
            <p>{item.text}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section commands-section" aria-labelledby="commands-title">
    <div class="section-heading">
      <p class="eyebrow">{t.commands.eyebrow}</p>
      <h2 id="commands-title">{t.commands.title}</h2>
    </div>
    <div class="command-grid">
      {
        t.commands.groups.map((group) => (
          <article class="command-card">
            <h3>{group.title}</h3>
            <ul>
              {group.items.map((item) => (
                <li><code>{item}</code></li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
    <a class="button secondary command-cta" href={`${docs}/comandos`}>{t.commands.cta}</a>
  </section>

  <section class="final-cta" aria-labelledby="final-title">
    <p class="eyebrow">{t.finalCta.eyebrow}</p>
    <h2 id="final-title">{t.finalCta.title}</h2>
    <div class="hero-actions center">
      <a class="button primary" href={`${docs}/instalacao`}>{t.finalCta.ctaInstall}</a>
      <a class="button secondary" href={docs}>{t.finalCta.ctaDocs}</a>
    </div>
  </section>

  <script is:inline>
    document.querySelectorAll("[data-install]").forEach((widget) => {
      const tabs = widget.querySelectorAll("[data-tab]");
      const panels = widget.querySelectorAll("[data-panel]");
      tabs.forEach((tab) => {
        tab.addEventListener("click", () => {
          const target = tab.getAttribute("data-tab");
          tabs.forEach((t) => {
            const active = t === tab;
            t.classList.toggle("is-active", active);
            t.setAttribute("aria-selected", active ? "true" : "false");
          });
          panels.forEach((panel) => {
            const active = panel.getAttribute("data-panel") === target;
            panel.classList.toggle("is-active", active);
            panel.hidden = !active;
          });
        });
      });
    });
  </script>
</BaseLayout>
